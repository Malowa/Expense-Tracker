import csv
import os
import tkinter as tk
from tkinter import filedialog, messagebox, ttk
from datetime import datetime
import matplotlib.pyplot as plt
from collections import defaultdict

FILE_NAME = 'transactions.csv'  # now stores both Income and Expenditure

def init_file():
    # create CSV with headers if missing
    if not os.path.exists(FILE_NAME):
        with open(FILE_NAME, mode='w', newline='') as file:
            writer = csv.writer(file)
            writer.writerow(['Date', 'Type', 'Category', 'Description', 'Amount'])

def add_transaction():
    date = date_entry.get().strip()
    ttype = type_var.get().strip()  # "Income" or "Expenditure"
    category = category_entry.get().strip()
    description = description_entry.get().strip()
    amount_text = amount_entry.get().strip()

    if not (date and ttype and category and description and amount_text):
        messagebox.showerror("Error", "All fields are required.")
        return

    # validate date
    try:
        datetime.strptime(date, '%Y-%m-%d')
    except ValueError:
        messagebox.showerror("Error", "Invalid date format. Use YYYY-MM-DD.")
        return

    # validate amount
    try:
        amount = float(amount_text)
    except ValueError:
        messagebox.showerror("Error", "Amount must be a number.")
        return

    if amount < 0:
        messagebox.showerror("Error", "Please enter a positive number for amount.")
        return

    # append row
    with open(FILE_NAME, mode='a', newline='') as file:
        writer = csv.writer(file)
        writer.writerow([date, ttype, category, description, f"{amount:.2f}"])

    messagebox.showinfo("Transaction added", f"{ttype} on {date} added successfully.")
    clear_entries()
    load_transactions()

def clear_entries():
    # keep date default
    # date_entry.delete(0, tk.END)
    # date_entry.insert(0, datetime.now().strftime('%Y-%m-%d'))
    type_combo.set("Expenditure")
    category_entry.delete(0, tk.END)
    description_entry.delete(0, tk.END)
    amount_entry.delete(0, tk.END)

def load_transactions():
    # clear table
    for row in trans_table.get_children():
        trans_table.delete(row)

    total_income = 0.0
    total_expenditure = 0.0

    if os.path.exists(FILE_NAME):
        with open(FILE_NAME, mode='r', newline='') as file:
            reader = csv.DictReader(file)
            for row in reader:
                trans_table.insert("", tk.END, values=(
                    row["Date"], row["Type"], row["Category"], row["Description"], row["Amount"]
                ))
                amt = 0.0
                try:
                    amt = float(row["Amount"])
                except Exception:
                    pass
                if row["Type"].lower() == "income":
                    total_income += amt
                else:
                    total_expenditure += amt
    else:
        messagebox.showinfo("Info", "No transactions file found. A new one will be created when you add a transaction.")

    net = total_income - total_expenditure
    total_label.config(text=f"Income: KES {total_income:.2f}    Expenditure: KES {total_expenditure:.2f}    Net: KES {net:.2f}")

def search_transactions(query):
    query = query.strip().lower()
    for row in trans_table.get_children():
        trans_table.delete(row)

    total_income = 0.0
    total_expenditure = 0.0
    found = False

    if os.path.exists(FILE_NAME):
        with open(FILE_NAME, mode='r', newline='') as file:
            reader = csv.DictReader(file)
            for row in reader:
                if (query in row["Category"].lower()) or (query in row["Description"].lower()) or (query in row["Type"].lower()):
                    trans_table.insert("", tk.END, values=(
                        row["Date"], row["Type"], row["Category"], row["Description"], row["Amount"]
                    ))
                    found = True
                    try:
                        amt = float(row["Amount"])
                    except Exception:
                        amt = 0.0
                    if row["Type"].lower() == "income":
                        total_income += amt
                    else:
                        total_expenditure += amt
        if not found:
            messagebox.showinfo("Search Result", "No transactions found matching your search.")
    else:
        messagebox.showerror("Error", "No transactions found.")

    net = total_income - total_expenditure
    total_label.config(text=f"Income: KES {total_income:.2f}    Expenditure: KES {total_expenditure:.2f}    Net: KES {net:.2f}")

def delete_transaction():
    selected_item = trans_table.selection()
    if not selected_item:
        messagebox.showerror("Error", "No transaction selected.")
        return

    confirm = messagebox.askyesno("Delete", "Are you sure you want to delete the selected transaction?")
    if not confirm:
        return

    values = trans_table.item(selected_item, 'values')
    # values order: Date, Type, Category, Description, Amount
    date, ttype, category, description, amount = values

    # remove from treeview
    trans_table.delete(selected_item)
    # rebuild CSV without that exact row (first matching)
    updated_rows = []
    deleted = False
    if os.path.exists(FILE_NAME):
        with open(FILE_NAME, mode='r') as file:
            reader = csv.DictReader(file)
            for row in reader:
                if (not deleted) and row['Date'] == date and row['Type'] == ttype and row['Category'] == category and row['Description'] == description and row['Amount'] == amount:
                    deleted = True
                    continue
                updated_rows.append(row)

        with open(FILE_NAME, mode='w', newline='') as file:
            fieldnames = ['Date', 'Type', 'Category', 'Description', 'Amount']
            writer = csv.DictWriter(file, fieldnames=fieldnames)
            writer.writeheader()
            for r in updated_rows:
                writer.writerow(r)

    messagebox.showinfo("Deleted", "Transaction deleted successfully.")
    load_transactions()

def show_category_bar_chart():
    if not os.path.exists(FILE_NAME):
        messagebox.showerror("Error", "No transactions found to display.")
        return

    income_totals = defaultdict(float)
    expense_totals = defaultdict(float)

    with open(FILE_NAME, mode='r', newline='') as file:
        reader = csv.DictReader(file)
        for row in reader:
            category = row['Category']
            try:
                amount = float(row['Amount'])
            except Exception:
                amount = 0.0
            if row['Type'].lower() == 'income':
                income_totals[category] += amount
            else:
                expense_totals[category] += amount

    categories = sorted(set(list(income_totals.keys()) + list(expense_totals.keys())))
    if not categories:
        messagebox.showinfo("Info", "No category data to display.")
        return

    incomes = [income_totals.get(c, 0.0) for c in categories]
    expenses = [expense_totals.get(c, 0.0) for c in categories]

    x = range(len(categories))
    width = 0.35

    plt.figure(figsize=(12, 6))
    plt.bar([i - width/2 for i in x], incomes, width, label='Income', color='green')
    plt.bar([i + width/2 for i in x], expenses, width, label='Expenditure', color='red')
    plt.xlabel("Category")
    plt.ylabel("Amount (KES)")
    plt.title("Income vs Expenditure by Category")
    plt.xticks(x, categories, rotation=45, ha='right')
    plt.legend()
    plt.tight_layout()
    plt.show()

def show_spending_pie_chart():
    # pie for expenditures only
    if not os.path.exists(FILE_NAME):
        messagebox.showerror("Error", "No transactions found to display.")
        return

    expense_totals = defaultdict(float)
    with open(FILE_NAME, mode='r', newline='') as file:
        reader = csv.DictReader(file)
        for row in reader:
            if row['Type'].lower() != 'expenditure':
                continue
            category = row['Category']
            try:
                amount = float(row['Amount'])
            except Exception:
                amount = 0.0
            expense_totals[category] += amount

    if not expense_totals:
        messagebox.showinfo("Info", "No expenditure data to plot.")
        return

    categories = list(expense_totals.keys())
    totals = list(expense_totals.values())

    plt.figure(figsize=(6, 6))
    plt.pie(totals, labels=categories, autopct='%1.1f%%', startangle=140)
    plt.title("Expenditure Distribution by Category")
    plt.axis('equal')
    plt.tight_layout()
    plt.show()

def show_monthly_summary():
    if not os.path.exists(FILE_NAME):
        messagebox.showerror("Error", "No transactions found to display.")
        return

    monthly_income = defaultdict(float)
    monthly_expense = defaultdict(float)

    with open(FILE_NAME, mode='r', newline='') as file:
        reader = csv.DictReader(file)
        for row in reader:
            try:
                date = datetime.strptime(row['Date'], '%Y-%m-%d')
            except Exception:
                continue
            month_year = date.strftime('%Y-%m')
            try:
                amount = float(row['Amount'])
            except Exception:
                amount = 0.0
            if row['Type'].lower() == 'income':
                monthly_income[month_year] += amount
            else:
                monthly_expense[month_year] += amount

    months = sorted(set(list(monthly_income.keys()) + list(monthly_expense.keys())))
    if not months:
        messagebox.showinfo("Info", "No monthly data to display.")
        return

    incomes = [monthly_income.get(m, 0.0) for m in months]
    expenses = [monthly_expense.get(m, 0.0) for m in months]
    net = [inc - exp for inc, exp in zip(incomes, expenses)]

    plt.figure(figsize=(12, 6))
    x = range(len(months))
    width = 0.3
    plt.bar([i - width for i in x], incomes, width, label='Income', color='green')
    plt.bar([i for i in x], expenses, width, label='Expenditure', color='red')
    plt.bar([i + width for i in x], net, width, label='Net', color='skyblue')
    plt.xlabel("Month")
    plt.ylabel("Amount (KES)")
    plt.title("Monthly Income / Expenditure / Net")
    plt.xticks(x, months, rotation=45, ha='right')
    plt.legend()
    plt.tight_layout()
    plt.show()

def export_monthly_summary():
    if not os.path.exists(FILE_NAME):
        messagebox.showerror("Error", "No transactions found to export.")
        return

    monthly_income = defaultdict(float)
    monthly_expense = defaultdict(float)

    with open(FILE_NAME, mode='r', newline='') as file:
        reader = csv.DictReader(file)
        for row in reader:
            try:
                date = datetime.strptime(row['Date'], '%Y-%m-%d')
            except Exception:
                continue
            month_year = date.strftime('%Y-%m')
            try:
                amount = float(row['Amount'])
            except Exception:
                amount = 0.0
            if row['Type'].lower() == 'income':
                monthly_income[month_year] += amount
            else:
                monthly_expense[month_year] += amount

    months = sorted(set(list(monthly_income.keys()) + list(monthly_expense.keys())))
    if not months:
        messagebox.showinfo("Info", "No data to export")
        return

    with open('monthly_summary.csv', mode='w', newline='') as file:
        writer = csv.writer(file)
        writer.writerow(['Month', 'Income (KES)', 'Expenditure (KES)', 'Net (KES)'])
        for m in months:
            inc = monthly_income.get(m, 0.0)
            exp = monthly_expense.get(m, 0.0)
            net = inc - exp
            writer.writerow([m, f"{inc:.2f}", f"{exp:.2f}", f"{net:.2f}"])

    messagebox.showinfo("Exported", "Monthly summary exported successfully as monthly_summary.csv")

